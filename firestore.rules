rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && role in request.auth.token.roles;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isOwner() {
      return hasRole('owner');
    }

    function isCustomer() {
      return hasRole('customer');
    }

    function isOwnerOfShop(shopId) {
      return isAuthenticated()
        && get(/databases/$(database)/documents/pastryShops/$(shopId)).data.owner_id == request.auth.uid;
    }

    function isOwnerOfProduct(productId) {
      let product = get(/databases/$(database)/documents/products/$(productId));
      return product.exists && isOwnerOfShop(product.data.shop_id);
    }

    // ── users ──
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isAdmin() || request.auth.uid == userId;
    }

    // ── customers ──
    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == customerId;
      allow update, delete: if isAdmin() || request.auth.uid == customerId;
      match /addresses/{addressId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAdmin() || request.auth.uid == customerId;
      }
    }

    // ── pastryShops ──
    match /pastryShops/{shopId} {
      allow read: if true;  // public
      allow create: if isOwner() || isAdmin();
      allow update, delete: if isAdmin() || (isOwner() && resource.data.owner_id == request.auth.uid);
      match /schedules/{day} {
        allow read: if true;
        allow write: if isAdmin() || (isOwner() && get(/databases/$(database)/documents/pastryShops/$(shopId)).data.owner_id == request.auth.uid);
      }
      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isAdmin() || (isOwner() && get(/databases/$(database)/documents/pastryShops/$(shopId)).data.owner_id == request.auth.uid);
      }
    }

    // ── products ──
    match /products/{productId} {
      allow read: if true;  // public
      allow create: if isOwner() || isAdmin();
      allow update, delete: if isAdmin() || (isOwner() && resource.data.shop_id != null && get(/databases/$(database)/documents/pastryShops/$(resource.data.shop_id)).data.owner_id == request.auth.uid);
      match /variants/{variantId} {
        allow read: if true;
        allow write: if isAdmin() || (isOwner() && get(/databases/$(database)/documents/pastryShops/$(get(/databases/$(database)/documents/products/$(productId)).data.shop_id)).data.owner_id == request.auth.uid);
      }
    }

    // ── orders ──
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isCustomer() || isAdmin();
      allow update, delete: if isAdmin();
      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // ── payments ──
    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ── reviews ──
    match /reviews/{reviewId} {
      allow read: if true;  // public
      allow create: if isCustomer() || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── notifications ──
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || request.auth.uid == resource.data.user_id;
    }

    // ── reports ──
    match /reports/{reportId} {
      allow read: if isAdmin() || hasRole('moderator');
      allow create: if isAuthenticated();
      allow update: if isAdmin() || hasRole('moderator');
      allow delete: if isAdmin();
    }

    // ── chatSessions ──
    match /chatSessions/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    // ── supportTickets ──
    match /supportTickets/{ticketId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || hasRole('moderator');
      allow delete: if isAdmin();
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }
    }

    // ── invoices ──
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ── backupHistory ──
    match /backupHistory/{backupId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
