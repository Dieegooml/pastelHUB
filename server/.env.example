PORT=3001
NODE_ENV=development

# Firebase Admin SDK — opción A: archivo de credenciales
# 1. Descargar de Firebase Console > Project Settings > Service Accounts
# 2. Guardar como server/serviceAccountKey.json (NO se sube a git)
#
# Opción B: variable de entorno GOOGLE_APPLICATION_CREDENTIALS
# GOOGLE_APPLICATION_CREDENTIALS=C:/ruta/a/serviceAccountKey.json
#
# Opción C: variables individuales (para CI/CD)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# MercadoPago (opcional — si no se configura, se usa gateway simulado)
# MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxx-xxxxxx
# MERCADOPAGO_WEBHOOK_SECRET=tu_webhook_secret
# BACKEND_URL=http://localhost:3001
# CLIENT_URL=http://localhost:5173

# Backup
# BACKUP_BUCKET=pastehub-2d2b2-backups

# Security — IP blocking (comma-separated)
# BLOCKED_IPS=1.2.3.4,5.6.7.8

# Security — IP-based rate limiting (requests per minute)
# IP_RATE_LIMIT_MAX=100
