PORT=3001
NODE_ENV=development

# Firebase Admin SDK — opción A: archivo de credenciales
# 1. Descargar de Firebase Console > Project Settings > Service Accounts
# 2. Guardar como server/serviceAccountKey.json (NO se sube a git)
#
# Opción B: variable de entorno GOOGLE_APPLICATION_CREDENTIALS
# GOOGLE_APPLICATION_CREDENTIALS=C:/ruta/a/serviceAccountKey.json
#
# Opción C: variables individuales (para CI/CD)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=